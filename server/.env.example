# Server port
PORT=4000

# Database
DATABASE_URL="file:./dev.db"

# JWT Secret (min 32 chars)
JWT_SECRET="your-super-secret-jwt-key-min-32-chars-here"

# Firebase Admin SDK - paste your service account JSON or use path
# Option 1: Path to service account JSON file
FIREBASE_SERVICE_ACCOUNT_PATH="./firebase-service-account.json"

# Option 2: Or set the JSON as env var (for production)
# GOOGLE_APPLICATION_CREDENTIALS_JSON='{"type":"service_account",...}'

# Firebase Storage bucket (e.g. your-project.appspot.com)
FIREBASE_STORAGE_BUCKET="your-project.appspot.com"

# CORS - allowed client origin (e.g. http://localhost:3000)
CLIENT_ORIGIN="http://localhost:3000"
