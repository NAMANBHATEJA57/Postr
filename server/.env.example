# Server port
PORT=4000

# Database (PostgreSQL/Neon)
DATABASE_URL="postgresql://user:password@endpoint.neon.tech/dbname?sslmode=require"

# JWT Secret (min 32 chars)
JWT_SECRET="your-super-secret-jwt-key-min-32-chars-here"

# Application Layer Encryption Key for Database (must be 32+ chars)
ENCRYPTION_KEY="this-is-a-super-secret-master-key"

# Cloudinary Storage
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# CORS - allowed client origin (e.g. http://localhost:3000)
CLIENT_ORIGIN="http://localhost:3000"

# Rate Limiting (Upstash Redis)
UPSTASH_REDIS_REST_URL="your-upstash-redis-url"
UPSTASH_REDIS_REST_TOKEN="your-upstash-redis-token"

# Bot Protection (Cloudflare Turnstile)
TURNSTILE_SECRET_KEY="your-turnstile-secret-key"
